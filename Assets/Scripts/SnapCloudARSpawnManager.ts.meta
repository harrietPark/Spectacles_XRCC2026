  InputLines:
    - '// @input SceneObject targetModel {"hint":"LEGACY: pre-placed 3D model root (no longer used for spawning; URL load replaces it)."}'
    - '// @input SceneObject cameraObject {"hint":"Camera SceneObject used to place the spawned model in front of the user."}'
    - '// @input Asset.Material baseMaterial {"hint":"Base PBR material applied to the instantiated GLB (required by tryInstantiate)."}'
    - '// @input SceneObject spawnParent {"hint":"DEPRECATED/ignored: spawned models always parent to an auto-created static scene root so they stay world-locked."}'
    - '// @input string modelUrlColumn = "original_model_3d_url" {"hint":"Request column holding the GLB URL to download."}'
    - '// @input float modelScale = 1 {"hint":"Uniform scale applied to the spawned model (1 = no change)."}'
    - '// @input bool convertMetersToCentimeters = true {"hint":"Convert GLTF meters to Lens centimetres on instantiate (usually true)."}'
    - '// @input float spawnDistance = 50 {"hint":"Centimetres in front of the camera (50 = 0.5 m)."}'
    - '// @input float heightOffset {"hint":"Centimetres added to camera height when placing the model."}'
    - '// @input bool faceCamera = true {"hint":"Rotate the model so it faces the camera."}'
    - '// @input bool hideOnStart = true {"hint":"Hide targetModel on start."}'
    - '// @input bool ignoreEditorPreview = true {"hint":"If true, Lens Studio Preview will not claim web spawn requests. Leave on when testing on Spectacles."}'
    - '// @input float pollIntervalSeconds = 1 {"hint":"How often (seconds) to poll ar_spawn_requests."}'
    - '// @input string tableName = "ar_spawn_requests" {"hint":"Supabase table name for AR spawn requests."}'
    - '// @input bool debugLogs = true {"hint":"Enable verbose logs."}'
    - '// @input bool testMode {"hint":"TEST MODE: ignore spawn requests and load the hard-coded testModelUrl once on start."}'
    - '// @input string testModelUrl = "https://web-api.ikea.com/dimma/assets/1.2/20359154/PS01_S01_NV01/rqp3/glb_draco/20359154_PS01_S01_NV01_RQP3_3.0_298fca27ac4a41379a171d7e7aba1e9a.glb" {"hint":"Hard-coded GLB URL loaded when testMode is on."}'
    - '// @input Asset.ObjectPrefab grabbableWrapper {"hint":"Prefab with Collider + Interactable + InteractableManipulation. The GLB is parented under it for grabbing."}'
    - '// @input bool enableGrab = true {"hint":"Allow grabbing/manipulating spawned models (requires grabbableWrapper)."}'
    - '// @input float grabColliderPadding = 2 {"hint":"Extra padding (cm) added around the auto-fit grab collider."}'
