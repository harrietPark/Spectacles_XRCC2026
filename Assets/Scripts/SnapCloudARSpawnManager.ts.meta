  InputLines:
    - '// @input SceneObject targetModel {"hint":"LEGACY: pre-placed 3D model root (no longer used for spawning; URL load replaces it)."}'
    - '// @input SceneObject cameraObject {"hint":"Camera SceneObject used to place the spawned model in front of the user."}'
    - '// @input Asset.Material baseMaterial {"hint":"Base PBR material applied to the instantiated GLB (required by tryInstantiate)."}'
    - '// @input SceneObject spawnParent {"hint":"DEPRECATED/ignored: spawned models always parent to an auto-created static scene root so they stay world-locked."}'
    - '// @input string modelUrlColumn = "original_model_3d_url" {"hint":"Request column holding the GLB URL to download."}'
    - '// @input float modelScale = 1 {"hint":"Uniform scale applied to the spawned model (1 = no change)."}'
    - '// @input bool convertMetersToCentimeters = true {"hint":"Convert GLTF meters to Lens centimetres on instantiate (usually true)."}'
    - '// @input float spawnDistance = 50 {"hint":"Centimetres in front of the camera (50 = 0.5 m)."}'
    - '// @input float heightOffset {"hint":"Centimetres added to camera height when placing the model."}'
    - '// @input bool faceCamera = true {"hint":"Rotate the model so it faces the camera."}'
    - '// @input bool hideOnStart = true {"hint":"Hide targetModel on start."}'
    - '// @input bool ignoreEditorPreview = true {"hint":"If true, Lens Studio Preview will not claim web spawn requests. Leave on when testing on Spectacles."}'
    - '// @input float pollIntervalSeconds = 1 {"hint":"How often (seconds) to poll ar_spawn_requests."}'
    - '// @input string tableName = "ar_spawn_requests" {"hint":"Supabase table name for AR spawn requests."}'
    - '// @input bool debugLogs = true {"hint":"Enable verbose logs."}'
    - '// @input bool testMode {"hint":"TEST MODE: ignore spawn requests and load the hard-coded testModelUrl once on start."}'
    - '// @input string testModelUrl = "https://web-api.ikea.com/dimma/assets/1.2/20359154/PS01_S01_NV01/rqp3/glb_draco/20359154_PS01_S01_NV01_RQP3_3.0_298fca27ac4a41379a171d7e7aba1e9a.glb" {"hint":"Hard-coded GLB URL loaded when testMode is on."}'
    - '// @input Asset.ObjectPrefab grabbableWrapper {"hint":"Prefab with Collider + Interactable + InteractableManipulation. The GLB is parented under it for grabbing."}'
    - '// @input bool enableGrab = true {"hint":"Allow grabbing/manipulating spawned models (requires grabbableWrapper)."}'
    - '// @input float grabColliderPadding = 2 {"hint":"Extra padding (cm) added around the auto-fit parent box collider (the hover/reveal trigger)."}'
    - "// @input float grabHandleOffset = 3 {\"hint\":\"Distance (cm) the grab-handle spheres sit beyond the model's bounding box.\"}"
    - '// @input bool revealHandlesOnHover = true {"hint":"Hide grab handles until the hand hovers the model box or a handle."}'
    - '// @input float handleHideDelaySeconds = 0.3 {"hint":"Grace period (seconds) before hiding handles after the hand leaves, to avoid flicker when reaching for a handle."}'
    - '// @input Component.AudioComponent spawnSound {"hint":"Sound played once each time an AR model is spawned (optional)."}'
    - '// @input bool enableInfoCard = true {"hint":"Spawn a product info card (description + price) with each model."}'
    - '// @input Asset.ObjectPrefab infoCardPrefab {"hint":"Info card prefab (UI background + Text fields). Instantiated under the grabbable wrapper so it despawns with the model."}'
    - '// @input vec3 cardOffset = {0,20,0} {"hint":"Local offset (cm) of the info card relative to the model center."}'
    - '// @input string productsTableName = "products" {"hint":"Products catalog table to look up card text from."}'
    - '// @input string productKeyColumn = "id" {"hint":"Products column that ar_spawn_requests.product_id matches."}'
    - "// @input string descriptionColumn = \"description\" {\"hint\":\"Products column read into the card's description field.\"}"
    - "// @input string priceColumn = \"price\" {\"hint\":\"Products column read into the card's price field.\"}"
    - '// @input string descriptionObjectName = "description" {"hint":"Name of the SceneObject holding the description Text component inside the info card prefab."}'
    - '// @input string priceObjectName = "price" {"hint":"Name of the SceneObject holding the price Text component inside the info card prefab."}'
    - '// @input bool enableGridSnap = true {"hint":"Snap model position to a grid while dragging."}'
    - '// @input float gridSnapUnit = 5 {"hint":"Grid cell size in centimetres for translation snapping."}'
    - '// @input bool enableRotationSnap = true {"hint":"Snap Y-axis rotation to fixed steps while rotating."}'
    - '// @input float rotationSnapDegrees = 15 {"hint":"Rotation step in degrees for Y-axis snapping."}'
    - '// @input float rotationSmoothing = 0.3 {"hint":"Turntable smoothing (0 = instant/snappy, up to ~0.9 = very smooth but laggy). Dampens hand-tracking jitter."}'
