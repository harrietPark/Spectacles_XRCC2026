    - '// @input string capturesTableName = "captures" {"hint":"Table name used when syncCapturesTable is true"}'
    - '// @input string sessionsTableName = "sessions" {"hint":"Table name for session records. A row is inserted here on startup before any captures."}'
    - '// @input Component.RenderMeshVisual captureRendMesh {"hint":"Bridge: RenderMeshVisual whose mainPass.captureImage holds the cropped texture."}'
    - '// @input SceneObject loadingIndicator {"hint":"Bridge: SceneObject whose enabled state goes true when a capture is ready."}'
    - '// @input string bridgeCaption = "capture" {"hint":"Bridge: optional caption/title to attach to uploads from this bridge."}'
    - '// @input bool autoHideLoading = true {"hint":"Bridge: disable the loadingIndicator automatically when upload finishes (success or fail)."}'
