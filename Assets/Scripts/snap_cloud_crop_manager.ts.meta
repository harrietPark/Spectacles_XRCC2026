  InputLines:
    - '// @input Asset.SupabaseProject supabaseProject {"hint":"PinPoint Snap Cloud project asset (url + publicToken). Required on the manager instance."}'
    - '// @input bool saveToCloud = true {"hint":"Master switch for uploading cropped captures to Snap Cloud storage"}'
    - '// @input string storageBucket = "specs-captures" {"hint":"Supabase storage bucket name. Must match the bucket configured in the Snap Cloud dashboard."}'
