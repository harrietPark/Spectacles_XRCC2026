  InputLines:
    - '// @ui {"widget":"group_start", "label":"Visual Feedback"}'
    - // @input SceneObject MidasTouchVisual
    - '// @input Component.RenderMeshVisual midasTouchVisualMesh {"hint":"Optional mesh visual for dwell indicator color feedback. If empty, uses first RenderMeshVisual on MidasTouchVisual."}'
    - '// @input Asset.ObjectPrefab dwellNotReadyStatePrefab {"hint":"Optional prefab shown while dwell is not ready. Falls back to color sphere when unassigned."}'
    - '// @input Asset.ObjectPrefab dwellReadyStatePrefab {"hint":"Optional prefab shown when dwell is ready to place a note. Falls back to color sphere when unassigned."}'
    - '// @input float dwellNotReadyStateScale = 1 {"hint":"Uniform scale multiplier for the not-ready state prefab."}'
    - '// @input float dwellReadyStateScale = 1 {"hint":"Uniform scale multiplier for the ready state prefab."}'
    - '// @input string midasTouchColorParameter = "baseColor" {"hint":"Shader color parameter name on the dwell indicator material."}'
    - '// @input vec4 dwellNotReadyColor = {1,0,0,1} {"widget":"color"}'
    - '// @input vec4 dwellReadyColor = {0,1,0,1} {"widget":"color"}'
    - '// @input float dwellSignalDebounceSeconds = 0.08 {"hint":"Seconds the dwell signal must remain changed before applying state (reduces jitter flicker)."}'
    - '// @input float dwellReadyAfterSeconds = 1.5 {"hint":"Seconds in active dwell before switching from not-ready to ready visual."}'
    - '// @ui {"widget":"group_end"}'
    - '// @ui {"widget":"group_start", "label":"Post-Ready Loading"}'
    - '// @input bool showLoadingIndicator {"hint":"Show loading icon while note is being created after dwell is ready."}'
    - '// @input Asset.ObjectPrefab loadingIndicatorPrefab {"hint":"Optional loading indicator prefab. If empty, tries 3DLoadingIndicator__PLACE_IN_SCENE prefab."}'
    - '// @input vec3 loadingIndicatorLocalOffset = {0,-5,0} {"hint":"Offset from pin position in local space. Use negative Y to place below."}'
    - '// @input float loadingIndicatorScale = 1 {"hint":"Uniform scale multiplier for loading indicator."}'
    - '// @input AssignableType areaManagerForLoadingTracking {"hint":"Assign AreaManager to hide loading indicator when a new note widget is actually created."}'
    - '// @ui {"widget":"group_end"}'
